#+begin_src emacs-lisp :results none :eval always :exports none
(make-variable-buffer-local 'org-latex-default-packages-alist)
(make-variable-buffer-local 'org-latex-packages-alist)

(defun hz/org-latex-setup-koma-letter (backend)
  "Buffer-local overrides for koma-letter export."
  (when (org-export-derived-backend-p backend 'koma-letter)
    (setq-local org-latex-packages-alist nil)
    (setq-local org-latex-default-packages-alist nil)))
(add-hook 'org-export-before-processing-hook #'hz/org-latex-setup-koma-letter nil t)
