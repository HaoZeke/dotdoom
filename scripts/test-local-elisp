#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "${repo_root}"

shopt -s nullglob
test_files=(local/*-test.el)

if [[ ${#test_files[@]} -eq 0 ]]; then
  printf 'No local ERT tests found.\n' >&2
  exit 1
fi

for test_file in "${test_files[@]}"; do
  printf '==> %s\n' "${test_file}"
  emacs --batch -Q -L local -l "${test_file}" -f ert-run-tests-batch-and-exit
done
